# =============================================================================
# backup_tool environment configuration
# =============================================================================
# Copy this file to `.env` in the same directory as `config.py` and set values.
# `.env` is gitignored; never commit real secrets.
#
# Other settings:
#   - Path / snapshot exclusions: `backup_config.json` → key `blacklist` only.
#   - Force browser OAuth on a run: set shell env `BACKUP_INTERACTIVE=1` (see main.py).
# =============================================================================

# -----------------------------------------------------------------------------
# Google OAuth (required)
# -----------------------------------------------------------------------------
# Create an "Desktop app" OAuth client in Google Cloud Console → APIs & Services
# → Credentials. Use the client ID and secret here. First successful run stores
# refresh tokens in TOKEN_FILE (path below).

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# Google Drive layout (optional)
# -----------------------------------------------------------------------------
# Top-level Drive folder name created/used for uploads (created if missing).

GDRIVE_BACKUPS_FOLDER=backups

# If true, backups go under a subfolder named after this machine's hostname
# (inside GDRIVE_BACKUPS_FOLDER). If false, uploads go directly into that folder.
# Accepted: true/false, 1/0, yes/no, on (case-insensitive). Default: true.

USE_HOSTNAME_SUBFOLDER=true

# -----------------------------------------------------------------------------
# OAuth token storage (optional)
# -----------------------------------------------------------------------------
# Filename (under the package directory) for the saved user credentials JSON.
# Default: gdrive_token.json — add this file to .gitignore if you change the name.

TOKEN_FILE=gdrive_token.json

# -----------------------------------------------------------------------------
# Retention (optional)
# -----------------------------------------------------------------------------
# After each upload, oldest backups in the target folder may be deleted so at most
# this many files remain. Set to 0 to disable deletion. Default: 0.

RETENTION_COUNT=5
